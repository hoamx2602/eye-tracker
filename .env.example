# Database (required for API). Use pooled connection for serverless (Neon/Supabase).
# Example Neon: postgresql://user:pass@host/db?sslmode=require
# Example Supabase: use "Connection pooling" connection string (Transaction mode).
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: override API base URL from frontend (default: same origin /api).
# NEXT_PUBLIC_API_URL="https://your-app.vercel.app"

# Optional: skip full calibration for testing save/storage. When set to 1, after the first calibration phase (grid) only, app saves session and goes to Eye Tracking.
# NEXT_PUBLIC_CALIBRATION_TEST_MODE=1

# Neurological: [Neuro] logs — next dev bật mặc định; tắt trong dev: NEXT_PUBLIC_NEURO_DEBUG=0; production bật: =1
# NEXT_PUBLIC_NEURO_DEBUG=0

# Neurological results: dev tools. When set:
# - /neuro/done?preview=1 → mock data only (no DB).
# - /neuro/done with a real run: if testResults in DB is empty, UI shows mock + banner (so you can style without full runs).
# NEXT_PUBLIC_NEURO_DEV_PREVIEW=1

# Sau mỗi bài neurological: chuyển ngay tới /neuro/done?verify=1 để xem kết quả thật (không cần chạy hết battery).
# Hoặc trong DevTools: sessionStorage.setItem('neuro_verify_after_each','1')
# NEXT_PUBLIC_NEURO_VERIFY_AFTER_EACH=1

# Required for /api/upload (AWS S3 — calibration video & images).
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET="your-bucket-name"
# Optional: set S3_ACL_PUBLIC_READ=1 only if your bucket allows ACLs (public-read). Many buckets block ACLs by default.
# If the bucket has "Block all public access" on, either disable it for the bucket
# or add a bucket policy that allows GetObject for prefix "calibration/".

# Admin seed (for npm run db:seed). Do not commit real values.
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="your-secure-password"
# SEED_ADMIN_NAME="Admin"
# SEED_ADMIN_FORCE=1

# Admin register API: secret required to create admin when at least one admin exists.
# Send in header: x-admin-register-secret. If unset, registration only allowed when no admins exist.
# ADMIN_REGISTER_SECRET="your-secret"

# Admin login: JWT signing secret (min 16 chars). Used for admin_token cookie.
# JWT_SECRET="your-jwt-secret-at-least-16-chars"
