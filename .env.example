# Database (required for API). Use pooled connection for serverless (Neon/Supabase).
# Example Neon: postgresql://user:pass@host/db?sslmode=require
# Example Supabase: use "Connection pooling" connection string (Transaction mode).
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: frontend origin for CORS (API). Leave unset on Vercel to allow *.
# FRONTEND_ORIGIN="https://your-app.vercel.app"

# Optional: override API base URL from frontend (default: same origin /api).
# VITE_API_URL="https://your-app.vercel.app"
