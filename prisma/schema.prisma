generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                     String           @id @default(cuid())
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  config                 Json?
  validationErrors       Float[]          @default([])
  meanErrorPx            Float?
  status                 String?          @default("completed")
  videoUrl               String?
  calibrationImageUrls   Json?
  calibrationGazeSamples Json?
  demographics           Json?
  neurologicalRun        NeurologicalRun?
  testRun                TestRun?
}

model TestRun {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  trajectories Json
  createdAt    DateTime @default(now())
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model NeurologicalTestConfig {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name           String   @unique @default("default")
  testOrder      Json
  testParameters Json
  testEnabled    Json?
}

model NeurologicalRun {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  sessionId         String   @unique
  configSnapshot    Json?
  preSymptomScores  Json?
  postSymptomScores Json?
  testOrderSnapshot Json?
  testResults       Json?
  status            String   @default("in_progress")
  session           Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AppConfig {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String   @unique @default("default")
  config    Json
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}
