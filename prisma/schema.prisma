// Prisma schema — PostgreSQL (Neon/Supabase recommended for Vercel serverless)
// Run: npx prisma migrate dev (local) or npx prisma migrate deploy (CI/production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Snapshot of app config at session start (JSON)
  config Json?

  // Demographics at calibration time (age, gender, country, eyeConditions)
  demographics Json?

  // After calibration: validation errors per point (pixels), mean error
  validationErrors Float[] @default([])
  meanErrorPx      Float?

  status String? @default("completed")

  // Calibration capture: video + images (URLs from blob storage)
  videoUrl             String? @db.Text
  calibrationImageUrls Json?   // string[]

  // Eye tracking data during calibration: array of { screenX, screenY, features?, timestamp? }
  calibrationGazeSamples Json?

  // Test mode: target vs gaze time-series (one run per session)
  testRun TestRun?
}

model TestRun {
  id          String   @id @default(cuid())
  sessionId   String   @unique
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  // Array of { patternName, points: { t, targetX, targetY, gazeX, gazeY }[] }
  trajectories Json
  createdAt   DateTime @default(now())
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("admins")
}
